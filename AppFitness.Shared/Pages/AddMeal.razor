@page "/food/add"
@using AppFitness.Shared.Services
@using AppFitness.Shared.Models
@inject IMealLogService MealLog
@inject INutritionSearchService NutritionSearch
@inject IFoodRecognitionService FoodRecognition
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Añadir Comida</PageTitle>

<div class="page-add-meal">
    <div class="page-header">
        <a href="food" class="btn-back">← Volver</a>
        <h2>📸 Añadir Comida</h2>
    </div>

    <!-- Tipo y fecha -->
    <div class="card-fitness">
        <div class="form-row">
            <div class="form-group">
                <label>Tipo de comida</label>
                <select @bind="mealType" class="form-select-fitness">
                    @foreach (MealType t in Enum.GetValues(typeof(MealType)))
                    {
                        <option value="@t">@t</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label>Fecha</label>
                <input type="date" class="form-input-fitness" @bind="mealDate"
                       max="@DateTime.Today.ToString("yyyy-MM-dd")" />
            </div>
        </div>
    </div>

    <!-- CAMARA -->
    <div class="card-fitness card-camera">
        <div class="card-header-fitness">
            <span class="card-icon">📷</span>
            <span>Foto del plato</span>
        </div>

        @if (string.IsNullOrEmpty(photoPreviewUrl))
        {
            <div class="camera-actions">
                <button class="btn-camera" @onclick="OpenCamera" disabled="@isAnalyzing">
                    <span class="cam-icon">📷</span>
                    <span>Abrir cámara</span>
                </button>
                <button class="btn-gallery" @onclick="OpenGallery" disabled="@isAnalyzing">
                    <span class="cam-icon">🖼️</span>
                    <span>Galería</span>
                </button>
            </div>
            <p class="camera-hint">
                Haz una foto al plato y la IA detectará los ingredientes,
                estimará los gramos y calculará las kcal automáticamente
            </p>
            @if (!FoodRecognition.HasApiKey)
            {
                <div class="info-banner warn" style="margin-top:0.5rem;">
                    ⚠️ Sin API key configurada. Ve a
                    <a href="/profile" style="color:#facc15;font-weight:600;">⚙️ Perfil</a>
                    para añadir tu clave gratuita de Gemini y activar el análisis por foto.
                </div>
            }
        }
        else
        {
            <div class="photo-container">
                <img src="@photoPreviewUrl" class="photo-preview" alt="Foto del plato" />
                @if (isAnalyzing)
                {
                    <div class="analyzing-overlay">
                        <div class="analyzing-spinner"></div>
                        <p>🤖 Analizando ingredientes y calculando kcal…</p>
                    </div>
                }
            </div>
            <div class="photo-retake-row">
                <button class="btn-retake" @onclick="RetakePhoto" disabled="@isAnalyzing">
                    📷 Nueva foto
                </button>
                @if (!isAnalyzing && analysisResult == null)
                {
                    <button class="btn-analyze" @onclick="AnalyzePhoto">
                        🤖 Analizar
                    </button>
                }
            </div>
        }

        @if (!string.IsNullOrEmpty(recognitionError))
        {
            <div class="info-banner warn">
                ⚠️ @recognitionError

                @if (recognitionError.Contains("429") || recognitionError.Contains("límite") || recognitionError.Contains("disponible ahora"))
                {
                    <div class="error-actions">
                        <button class="btn-retry" @onclick="AnalyzePhoto" disabled="@isAnalyzing">
                            🔄 Reintentar
                        </button>
                    </div>
                }

                @if (recognitionError.Contains("API key") || recognitionError.Contains("GEMINI_API_KEY"))
                {
                    <div style="margin-top:0.5rem;font-size:0.8rem;">
                        👉 Obtén tu clave gratuita en
                        <a href="https://aistudio.google.com/app/apikey" target="_blank" style="color:#facc15;font-weight:600;">
                            aistudio.google.com
                        </a>
                        y añádela en <strong>GitHub → Settings → Secrets → GEMINI_API_KEY</strong>
                    </div>
                }
            </div>
        }

        @if (analysisResult != null && aiIngredients.Any())
        {
            <div class="recognition-results">
                <div class="dish-name-row">
                    <span class="dish-badge">🍽️ @analysisResult.DishName</span>
                    <span class="dish-total-kcal">
                        ~@(aiIngredients.Where(v => v.Selected)
                            .Sum(v => Math.Round(v.Ingredient.KcalPer100g * v.Grams / 100, 0))
                            .ToString("0")) kcal seleccionados
                    </span>
                </div>

                <p class="recognition-title">
                    ✨ Ingredientes detectados — ajusta los gramos si es necesario:
                </p>

                @foreach (var vm in aiIngredients)
                {
                    <div class="ai-ingredient-row @(vm.Selected ? "ai-selected" : "ai-unselected")">
                        <button class="ai-check-btn" @onclick="() => vm.Selected = !vm.Selected">
                            @(vm.Selected ? "✅" : "⬜")
                        </button>

                        <div class="ai-ingredient-body">
                            <input class="ai-name-input" @bind="vm.Ingredient.Name"
                                   placeholder="Nombre del ingrediente" />

                            <div class="ai-values-row">
                                <div class="ai-field">
                                    <label>Gramos</label>
                                    <input type="number" min="1" class="ai-num-input highlight"
                                           value="@vm.Grams"
                                           @onchange="e => OnFieldChange(e, v => vm.Grams = v)" />
                                </div>
                                <div class="ai-field">
                                    <label>Kcal/100g</label>
                                    <input type="number" min="0" class="ai-num-input"
                                           value="@vm.Ingredient.KcalPer100g"
                                           @onchange="e => OnFieldChange(e, v => vm.Ingredient.KcalPer100g = v)" />
                                </div>
                                <div class="ai-field">
                                    <label>P/100g</label>
                                    <input type="number" min="0" class="ai-num-input"
                                           value="@vm.Ingredient.ProteinPer100g"
                                           @onchange="e => OnFieldChange(e, v => vm.Ingredient.ProteinPer100g = v)" />
                                </div>
                                <div class="ai-field">
                                    <label>C/100g</label>
                                    <input type="number" min="0" class="ai-num-input"
                                           value="@vm.Ingredient.CarbsPer100g"
                                           @onchange="e => OnFieldChange(e, v => vm.Ingredient.CarbsPer100g = v)" />
                                </div>
                                <div class="ai-field">
                                    <label>G/100g</label>
                                    <input type="number" min="0" class="ai-num-input"
                                           value="@vm.Ingredient.FatPer100g"
                                           @onchange="e => OnFieldChange(e, v => vm.Ingredient.FatPer100g = v)" />
                                </div>
                            </div>

                            <div class="ai-totals">
                                <span class="ai-total-kcal">
                                    🔥 @(Math.Round(vm.Ingredient.KcalPer100g * vm.Grams / 100, 0)) kcal
                                </span>
                                <span class="p-tag macro-tag">P: @(Math.Round(vm.Ingredient.ProteinPer100g * vm.Grams / 100, 1))g</span>
                                <span class="c-tag macro-tag">C: @(Math.Round(vm.Ingredient.CarbsPer100g * vm.Grams / 100, 1))g</span>
                                <span class="f-tag macro-tag">G: @(Math.Round(vm.Ingredient.FatPer100g * vm.Grams / 100, 1))g</span>
                            </div>
                        </div>

                        <button class="btn-remove" @onclick="() => aiIngredients.Remove(vm)"
                                title="Eliminar ingrediente">✕</button>
                    </div>
                }

                <button class="btn-add-manual ai-add-extra" @onclick="AddExtraAiIngredient">
                    + Añadir ingrediente
                </button>

                <button class="btn-add-recognized"
                        @onclick="AddAiIngredientsToMeal"
                        disabled="@(!aiIngredients.Any(v => v.Selected))">
                    ➕ Añadir @(aiIngredients.Count(v => v.Selected)) ingrediente(s) a la comida
                </button>
            </div>
        }
    </div>

    <!-- BUSQUEDA MANUAL -->
    <div class="card-fitness">
        <div class="card-header-fitness">
            <span class="card-icon">🔍</span>
            <span>Buscar alimento manualmente</span>
        </div>
        <div class="search-bar">
            <input type="text" class="form-input-fitness"
                   placeholder="Escribe el nombre del alimento…"
                   @bind="searchQuery" @bind:event="oninput"
                   @onkeydown="HandleSearchKeydown" />
            <button class="btn-search" @onclick="SearchFood" disabled="@isSearching">
                @(isSearching ? "⏳" : "🔍 Buscar")
            </button>
        </div>
        @if (apiUnavailable)
        {
            <div class="info-banner">📴 Búsqueda online no disponible — mostrando catálogo local.</div>
        }
        @if (searchResults.Any())
        {
            <div class="search-results">
                @foreach (var item in searchResults)
                {
                    <div class="search-result-item" @onclick="() => AddFromSearch(item)">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" class="food-thumb" alt="@item.Name"
                                 onerror="this.style.display='none'" />
                        }
                        else
                        {
                            <span class="food-thumb-placeholder">🍽️</span>
                        }
                        <div class="result-info">
                            <span class="result-name">@item.Name</span>
                            <span class="result-macros">
                                🔥 @item.KcalPer100g.ToString("0") kcal &nbsp;
                                P: @item.ProteinPer100g.ToString("0")g &nbsp;
                                C: @item.CarbsPer100g.ToString("0")g &nbsp;
                                G: @item.FatPer100g.ToString("0")g
                            </span>
                        </div>
                        <span class="result-add">+</span>
                    </div>
                }
            </div>
        }
        @if (searchPerformed && !searchResults.Any() && !isSearching)
        {
            <p class="empty-state">Sin resultados para «@lastQuery». Añade manualmente ↓</p>
        }
    </div>

    <!-- LISTA FINAL -->
    <div class="card-fitness">
        <div class="card-header-fitness">
            <span class="card-icon">🧺</span>
            <span>Alimentos en esta comida</span>
            @if (selectedFoods.Any())
            {
                <span class="meal-kcal-badge">
                    @selectedFoods.Sum(f => f.TotalKcal).ToString("0") kcal
                </span>
            }
        </div>
        @if (!selectedFoods.Any())
        {
            <p class="empty-state">Haz una foto o busca alimentos para añadirlos aquí.</p>
        }
        else
        {
            @foreach (var food in selectedFoods)
            {
                <div class="selected-food-row">
                    <div class="selected-food-info">
                        <input class="food-name-input" @bind="food.Name" placeholder="Nombre" />
                        <div class="food-edit-row">
                            <div class="food-edit-field">
                                <label>Cantidad (g)</label>
                                <input type="number" min="1" class="qty-input"
                                       value="@food.QuantityGrams"
                                       @onchange="e => OnFieldChange(e, v => food.QuantityGrams = v)" />
                            </div>
                            <div class="food-edit-field">
                                <label>Kcal/100g</label>
                                <input type="number" min="0" class="qty-input"
                                       value="@food.KcalPer100g"
                                       @onchange="e => OnFieldChange(e, v => food.KcalPer100g = v)" />
                            </div>
                            <div class="food-edit-field">
                                <label>P/100g</label>
                                <input type="number" min="0" class="qty-input" @bind="food.ProteinPer100g" />
                            </div>
                            <div class="food-edit-field">
                                <label>C/100g</label>
                                <input type="number" min="0" class="qty-input" @bind="food.CarbsPer100g" />
                            </div>
                            <div class="food-edit-field">
                                <label>G/100g</label>
                                <input type="number" min="0" class="qty-input" @bind="food.FatPer100g" />
                            </div>
                        </div>
                        <div class="food-totals">
                            <span>🔥 @food.TotalKcal.ToString("0") kcal</span>
                            <span class="protein">P: @food.TotalProtein.ToString("0")g</span>
                            <span class="carbs">C: @food.TotalCarbs.ToString("0")g</span>
                            <span class="fat">G: @food.TotalFat.ToString("0")g</span>
                        </div>
                    </div>
                    <button class="btn-remove" @onclick="() => RemoveFood(food)" title="Eliminar">✕</button>
                </div>
            }
            <div class="meal-total">
                <strong>Total: @selectedFoods.Sum(f => f.TotalKcal).ToString("0") kcal</strong>
                <span class="macro-tag p-tag">P: @selectedFoods.Sum(f => f.TotalProtein).ToString("0")g</span>
                <span class="macro-tag c-tag">C: @selectedFoods.Sum(f => f.TotalCarbs).ToString("0")g</span>
                <span class="macro-tag f-tag">G: @selectedFoods.Sum(f => f.TotalFat).ToString("0")g</span>
            </div>
        }
        <button class="btn-add-manual" @onclick="AddManualFood">+ Añadir alimento manualmente</button>
    </div>

    <!-- Notas -->
    <div class="card-fitness">
        <label>Notas (opcional)</label>
        <textarea class="form-textarea-fitness" @bind="notes"
                  placeholder="Ej: Restaurante El Rincón…"></textarea>
    </div>

    <!-- Guardar -->
    <div class="action-row">
        <button class="btn-save" @onclick="SaveMeal" disabled="@(!selectedFoods.Any())">
            💾 Guardar comida
        </button>
    </div>

    @if (!string.IsNullOrEmpty(errorMsg))
    {
        <p class="alert-error">@errorMsg</p>
    }
</div>

@code {
    [SupplyParameterFromQuery] public string? date { get; set; }
    [SupplyParameterFromQuery] public int? type { get; set; }

    private MealType mealType = MealType.Almuerzo;
    private DateTime mealDate = DateTime.Today;
    private string notes = string.Empty;
    private string errorMsg = string.Empty;

    private string? photoPreviewUrl;
    private byte[]? photoBytes;
    private string photoMime = "image/jpeg";
    private bool isAnalyzing = false;
    private string recognitionError = string.Empty;
    private FoodAnalysisResult? analysisResult;
    private List<AiIngredientVm> aiIngredients = new();

    private string searchQuery = string.Empty;
    private string lastQuery = string.Empty;
    private bool isSearching = false;
    private bool searchPerformed = false;
    private bool apiUnavailable = false;
    private List<FoodItem> searchResults = new();
    private List<FoodItem> selectedFoods = new();

    private class AiIngredientVm
    {
        public DetectedIngredient Ingredient { get; set; } = new();
        public double Grams
        {
            get => Ingredient.EstimatedGrams;
            set => Ingredient.EstimatedGrams = value;
        }
        public bool Selected { get; set; } = true;
    }

    protected override void OnInitialized()
    {
        if (!string.IsNullOrEmpty(date) && DateTime.TryParse(date, out var d))
            mealDate = d;
        if (type.HasValue && Enum.IsDefined(typeof(MealType), type.Value))
            mealType = (MealType)type.Value;
    }

    private async Task OpenCamera()  => await CaptureImage("capturePhoto");
    private async Task OpenGallery() => await CaptureImage("selectFromGallery");

    private async Task CaptureImage(string jsMethod)
    {
        recognitionError = string.Empty;
        analysisResult   = null;
        aiIngredients    = new();
        try
        {
            var result = await JS.InvokeAsync<CameraResult?>("cameraModule." + jsMethod);
            if (result == null) return;
            photoPreviewUrl = result.DataUrl;
            photoMime       = result.MimeType ?? "image/jpeg";
            photoBytes      = Convert.FromBase64String(result.Base64);
            await AnalyzePhoto();
        }
        catch (Exception ex)
        {
            recognitionError = "No se pudo acceder a la cámara: " + ex.Message;
        }
    }

    private void RetakePhoto()
    {
        photoPreviewUrl  = null;
        photoBytes       = null;
        analysisResult   = null;
        aiIngredients    = new();
        recognitionError = string.Empty;
    }

    private async Task AnalyzePhoto()
    {
        if (photoBytes == null) return;
        isAnalyzing      = true;
        recognitionError = string.Empty;
        analysisResult   = null;
        aiIngredients    = new();
        StateHasChanged();

        var result = await FoodRecognition.AnalyzeImageAsync(photoBytes, photoMime);
        isAnalyzing = false;

        if (!result.Success)
        {
            recognitionError = result.Error!;
            StateHasChanged();
            return;
        }

        analysisResult = result;
        aiIngredients  = result.Ingredients
            .Select(i => new AiIngredientVm { Ingredient = i, Selected = true })
            .ToList();
        StateHasChanged();
    }

    private void AddExtraAiIngredient()
    {
        aiIngredients.Add(new AiIngredientVm
        {
            Ingredient = new DetectedIngredient { Name = "Nuevo ingrediente", EstimatedGrams = 100 },
            Selected   = true
        });
    }

    private void AddAiIngredientsToMeal()
    {
        foreach (var vm in aiIngredients.Where(v => v.Selected))
        {
            selectedFoods.Add(new FoodItem
            {
                Name           = vm.Ingredient.Name,
                QuantityGrams  = vm.Grams,
                KcalPer100g    = vm.Ingredient.KcalPer100g,
                ProteinPer100g = vm.Ingredient.ProteinPer100g,
                CarbsPer100g   = vm.Ingredient.CarbsPer100g,
                FatPer100g     = vm.Ingredient.FatPer100g
            });
        }
        analysisResult = null;
        aiIngredients  = new();
    }

    private async Task HandleSearchKeydown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SearchFood();
    }

    private async Task SearchFood()
    {
        if (string.IsNullOrWhiteSpace(searchQuery)) return;
        isSearching     = true;
        searchPerformed = true;
        lastQuery       = searchQuery;
        searchResults   = new();
        apiUnavailable  = false;
        StateHasChanged();
        var results    = await NutritionSearch.SearchFoodAsync(searchQuery);
        apiUnavailable = results.Any() && results.All(r => r.ImageUrl == null);
        searchResults  = results;
        isSearching    = false;
    }

    private void AddFromSearch(FoodItem item)
    {
        selectedFoods.Add(new FoodItem
        {
            Name           = item.Name,
            KcalPer100g    = item.KcalPer100g,
            ProteinPer100g = item.ProteinPer100g,
            CarbsPer100g   = item.CarbsPer100g,
            FatPer100g     = item.FatPer100g,
            ImageUrl       = item.ImageUrl,
            QuantityGrams  = 100
        });
        searchResults   = new();
        searchQuery     = string.Empty;
        searchPerformed = false;
        apiUnavailable  = false;
    }

    private void AddManualFood()
        => selectedFoods.Add(new FoodItem { Name = "Nuevo alimento", QuantityGrams = 100 });

    private void RemoveFood(FoodItem food) => selectedFoods.Remove(food);

    private async Task SaveMeal()
    {
        if (!selectedFoods.Any()) { errorMsg = "Añade al menos un alimento."; return; }
        await MealLog.SaveAsync(new MealEntry
        {
            Date     = mealDate,
            MealType = mealType,
            Foods    = new List<FoodItem>(selectedFoods),
            Notes    = notes
        });
        Nav.NavigateTo("food");
    }

    private void OnFieldChange(ChangeEventArgs e, Action<double> setter)
    {
        if (double.TryParse(e.Value?.ToString(),
            System.Globalization.NumberStyles.Any,
            System.Globalization.CultureInfo.InvariantCulture, out var v))
            setter(v);
        StateHasChanged();
    }

    private class CameraResult
    {
        [System.Text.Json.Serialization.JsonPropertyName("base64")]
        public string Base64 { get; set; } = string.Empty;

        [System.Text.Json.Serialization.JsonPropertyName("mimeType")]
        public string MimeType { get; set; } = "image/jpeg";

        [System.Text.Json.Serialization.JsonPropertyName("dataUrl")]
        public string DataUrl { get; set; } = string.Empty;
    }
}
