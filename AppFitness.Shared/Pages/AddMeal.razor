@page "/food/add"
@using AppFitness.Shared.Services
@using AppFitness.Shared.Models
@inject IMealLogService MealLog
@inject INutritionSearchService NutritionSearch
@inject IFoodRecognitionService FoodRecognition
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Añadir Comida</PageTitle>

<div class="page-add-meal">
    <div class="page-header">
        <a href="food" class="btn-back">← Volver</a>
        <h2>📸 Añadir Comida</h2>
    </div>

    <!-- Tipo y fecha -->
    <div class="card-fitness">
        <div class="form-row">
            <div class="form-group">
                <label>Tipo de comida</label>
                <select @bind="mealType" class="form-select-fitness">
                    @foreach (MealType t in Enum.GetValues(typeof(MealType)))
                    {
                        <option value="@t">@t</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label>Fecha</label>
                <input type="date" class="form-input-fitness" @bind="mealDate"
                       max="@DateTime.Today.ToString("yyyy-MM-dd")" />
            </div>
        </div>
    </div>

    <!-- ═══ SECCIÓN CÁMARA / FOTO ══════════════════════════════════════════ -->
    <div class="card-fitness card-camera">
        <div class="card-header-fitness">
            <span class="card-icon">📷</span>
            <span>Foto de la comida</span>
        </div>

        @if (string.IsNullOrEmpty(photoPreviewUrl))
        {
            <!-- Botones de captura -->
            <div class="camera-actions">
                <button class="btn-camera" @onclick="OpenCamera" disabled="@isAnalyzing">
                    <span class="cam-icon">📷</span>
                    <span>Abrir cámara</span>
                </button>
                <button class="btn-gallery" @onclick="OpenGallery" disabled="@isAnalyzing">
                    <span class="cam-icon">🖼️</span>
                    <span>Galería</span>
                </button>
            </div>
            <p class="camera-hint">
                Haz una foto a tu plato y la IA detectará los alimentos automáticamente
            </p>
        }
        else
        {
            <!-- Preview de la foto + estado de análisis -->
            <div class="photo-container">
                <img src="@photoPreviewUrl" class="photo-preview" alt="Foto de la comida" />

                @if (isAnalyzing)
                {
                    <div class="analyzing-overlay">
                        <div class="analyzing-spinner"></div>
                        <p>🔍 Analizando alimentos…</p>
                    </div>
                }
            </div>

            <div class="photo-retake-row">
                <button class="btn-retake" @onclick="RetakePhoto" disabled="@isAnalyzing">
                    📷 Nueva foto
                </button>
                @if (!isAnalyzing && !recognizedFoods.Any() && !recognitionDone)
                {
                    <button class="btn-analyze" @onclick="AnalyzePhoto">
                        🔍 Analizar foto
                    </button>
                }
            </div>
        }

        <!-- ─── Resultados del reconocimiento IA ─── -->
        @if (recognitionDone && recognizedFoods.Any())
        {
            <div class="recognition-results">
                <p class="recognition-title">
                    ✨ Alimentos detectados — selecciona los que quieres añadir:
                </p>
                @foreach (var rf in recognizedFoods)
                {
                    <div class="recognition-item @(rf.Selected ? "selected" : "")"
                         @onclick="() => rf.Selected = !rf.Selected">
                        <div class="recognition-check">
                            @(rf.Selected ? "✅" : "⬜")
                        </div>
                        <div class="recognition-info">
                            <span class="recognition-name">@rf.Name</span>
                            <span class="recognition-confidence">
                                @rf.State switch
                                {
                                    RecognitionState.Pending   => "⏳ Buscando datos…",
                                    RecognitionState.Found     => $"🔥 {rf.FoodData?.KcalPer100g.ToString("0")} kcal/100g",
                                    RecognitionState.NotFound  => "⚠️ Sin datos — edita manualmente",
                                    _                          => $"{(rf.Confidence * 100):0}% confianza"
                                }
                            </span>
                        </div>
                        @if (rf.State == RecognitionState.Found && rf.FoodData != null)
                        {
                            <div class="recognition-macros">
                                <span class="p-tag macro-tag">P:@rf.FoodData.ProteinPer100g.ToString("0")g</span>
                                <span class="c-tag macro-tag">C:@rf.FoodData.CarbsPer100g.ToString("0")g</span>
                                <span class="f-tag macro-tag">G:@rf.FoodData.FatPer100g.ToString("0")g</span>
                            </div>
                        }
                    </div>
                }

                <button class="btn-add-recognized"
                        @onclick="AddRecognizedFoods"
                        disabled="@(!recognizedFoods.Any(r => r.Selected && r.State == RecognitionState.Found))">
                    ➕ Añadir seleccionados
                </button>
            </div>
        }

        @if (recognitionDone && !recognizedFoods.Any())
        {
            <div class="info-banner">
                😕 No se detectaron alimentos. Prueba con otra foto o busca manualmente.
            </div>
        }

        @if (!string.IsNullOrEmpty(recognitionError))
        {
            <div class="info-banner warn">⚠️ @recognitionError</div>
        }
    </div>

    <!-- ═══ BÚSQUEDA MANUAL ════════════════════════════════════════════════ -->
    <div class="card-fitness">
        <div class="card-header-fitness">
            <span class="card-icon">🔍</span>
            <span>Buscar alimento manualmente</span>
        </div>

        <div class="search-bar">
            <input type="text" class="form-input-fitness"
                   placeholder="Escribe el nombre del alimento…"
                   @bind="searchQuery" @bind:event="oninput"
                   @onkeydown="HandleSearchKeydown" />
            <button class="btn-search" @onclick="SearchFood" disabled="@isSearching">
                @(isSearching ? "⏳" : "🔍 Buscar")
            </button>
        </div>

        @if (apiUnavailable)
        {
            <div class="info-banner">
                📴 Búsqueda online no disponible — mostrando catálogo local.
            </div>
        }

        @if (searchResults.Any())
        {
            <div class="search-results">
                @foreach (var item in searchResults)
                {
                    <div class="search-result-item" @onclick="() => AddFromSearch(item)">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" class="food-thumb" alt="@item.Name"
                                 onerror="this.style.display='none'" />
                        }
                        else
                        {
                            <span class="food-thumb-placeholder">🍽️</span>
                        }
                        <div class="result-info">
                            <span class="result-name">@item.Name</span>
                            <span class="result-macros">
                                🔥 @item.KcalPer100g.ToString("0") kcal &nbsp;
                                P: @item.ProteinPer100g.ToString("0")g &nbsp;
                                C: @item.CarbsPer100g.ToString("0")g &nbsp;
                                G: @item.FatPer100g.ToString("0")g
                            </span>
                        </div>
                        <span class="result-add">+</span>
                    </div>
                }
            </div>
        }
        @if (searchPerformed && !searchResults.Any() && !isSearching)
        {
            <p class="empty-state">
                Sin resultados para «@lastQuery». Añade manualmente ↓
            </p>
        }
    </div>

    <!-- ═══ LISTA DE ALIMENTOS AÑADIDOS ═══════════════════════════════════ -->
    <div class="card-fitness">
        <div class="card-header-fitness">
            <span class="card-icon">🧺</span>
            <span>Alimentos en esta comida</span>
            @if (selectedFoods.Any())
            {
                <span class="meal-kcal-badge">
                    @selectedFoods.Sum(f => f.TotalKcal).ToString("0") kcal
                </span>
            }
        </div>

        @if (!selectedFoods.Any())
        {
            <p class="empty-state">
                Haz una foto o busca alimentos para añadirlos aquí.
            </p>
        }
        else
        {
            @foreach (var food in selectedFoods)
            {
                <div class="selected-food-row">
                    <div class="selected-food-info">
                        <input class="food-name-input" @bind="food.Name"
                               placeholder="Nombre del alimento" />
                        <div class="food-edit-row">
                            <div class="food-edit-field">
                                <label>Cantidad (g)</label>
                                <input type="number" min="1" @bind="food.QuantityGrams" class="qty-input" />
                            </div>
                            <div class="food-edit-field">
                                <label>Kcal/100g</label>
                                <input type="number" min="0" @bind="food.KcalPer100g" class="qty-input" />
                            </div>
                            <div class="food-edit-field">
                                <label>P/100g</label>
                                <input type="number" min="0" @bind="food.ProteinPer100g" class="qty-input" />
                            </div>
                            <div class="food-edit-field">
                                <label>C/100g</label>
                                <input type="number" min="0" @bind="food.CarbsPer100g" class="qty-input" />
                            </div>
                            <div class="food-edit-field">
                                <label>G/100g</label>
                                <input type="number" min="0" @bind="food.FatPer100g" class="qty-input" />
                            </div>
                        </div>
                        <div class="food-totals">
                            <span>🔥 @food.TotalKcal.ToString("0") kcal</span>
                            <span class="protein">P: @food.TotalProtein.ToString("0")g</span>
                            <span class="carbs">C: @food.TotalCarbs.ToString("0")g</span>
                            <span class="fat">G: @food.TotalFat.ToString("0")g</span>
                        </div>
                    </div>
                    <button class="btn-remove" @onclick="() => RemoveFood(food)" title="Eliminar">✕</button>
                </div>
            }

            <div class="meal-total">
                <strong>Total: @selectedFoods.Sum(f => f.TotalKcal).ToString("0") kcal</strong>
                <span class="macro-tag p-tag">P: @selectedFoods.Sum(f => f.TotalProtein).ToString("0")g</span>
                <span class="macro-tag c-tag">C: @selectedFoods.Sum(f => f.TotalCarbs).ToString("0")g</span>
                <span class="macro-tag f-tag">G: @selectedFoods.Sum(f => f.TotalFat).ToString("0")g</span>
            </div>
        }

        <button class="btn-add-manual" @onclick="AddManualFood">
            + Añadir alimento manualmente
        </button>
    </div>

    <!-- Notas -->
    <div class="card-fitness">
        <label>Notas (opcional)</label>
        <textarea class="form-textarea-fitness" @bind="notes"
                  placeholder="Ej: Restaurante El Rincón…"></textarea>
    </div>

    <!-- Guardar -->
    <div class="action-row">
        <button class="btn-save" @onclick="SaveMeal" disabled="@(!selectedFoods.Any())">
            💾 Guardar comida
        </button>
    </div>

    @if (!string.IsNullOrEmpty(errorMsg))
    {
        <p class="alert-error">@errorMsg</p>
    }
</div>

@code {
    // ─── Parámetros de URL ───────────────────────────────────────────────
    [SupplyParameterFromQuery] public string? date { get; set; }
    [SupplyParameterFromQuery] public int? type { get; set; }

    // ─── Estado general ──────────────────────────────────────────────────
    private MealType mealType = MealType.Almuerzo;
    private DateTime mealDate = DateTime.Today;
    private string notes = string.Empty;
    private string errorMsg = string.Empty;

    // ─── Foto y reconocimiento ───────────────────────────────────────────
    private string? photoPreviewUrl;
    private byte[]? photoBytes;
    private string photoMime = "image/jpeg";
    private bool isAnalyzing = false;
    private bool recognitionDone = false;
    private string recognitionError = string.Empty;
    private List<RecognizedFoodVm> recognizedFoods = new();

    // ─── Búsqueda manual ─────────────────────────────────────────────────
    private string searchQuery = string.Empty;
    private string lastQuery = string.Empty;
    private bool isSearching = false;
    private bool searchPerformed = false;
    private bool apiUnavailable = false;
    private List<FoodItem> searchResults = new();

    // ─── Alimentos seleccionados ─────────────────────────────────────────
    private List<FoodItem> selectedFoods = new();

    // ─── ViewModel reconocimiento ─────────────────────────────────────────
    private enum RecognitionState { Idle, Pending, Found, NotFound }

    private class RecognizedFoodVm
    {
        public string Name { get; set; } = string.Empty;
        public double Confidence { get; set; }
        public bool Selected { get; set; } = true;
        public RecognitionState State { get; set; } = RecognitionState.Idle;
        public FoodItem? FoodData { get; set; }
    }

    // ─── Init ─────────────────────────────────────────────────────────────
    protected override void OnInitialized()
    {
        if (!string.IsNullOrEmpty(date) && DateTime.TryParse(date, out var d))
            mealDate = d;
        if (type.HasValue && Enum.IsDefined(typeof(MealType), type.Value))
            mealType = (MealType)type.Value;
    }

    // ─── Cámara / galería ─────────────────────────────────────────────────
    private async Task OpenCamera()
    {
        await CaptureImage("capturePhoto");
    }

    private async Task OpenGallery()
    {
        await CaptureImage("selectFromGallery");
    }

    private async Task CaptureImage(string jsMethod)
    {
        recognitionError = string.Empty;
        recognitionDone = false;
        recognizedFoods = new();

        try
        {
            var result = await JS.InvokeAsync<CameraResult?>("cameraModule." + jsMethod);
            if (result == null) return;

            photoPreviewUrl = result.DataUrl;
            photoMime = result.MimeType ?? "image/jpeg";
            // Convertir base64 a bytes
            photoBytes = Convert.FromBase64String(result.Base64);

            // Analizar automáticamente al capturar
            await AnalyzePhoto();
        }
        catch (Exception ex)
        {
            recognitionError = "No se pudo acceder a la cámara: " + ex.Message;
        }
    }

    private void RetakePhoto()
    {
        photoPreviewUrl = null;
        photoBytes = null;
        recognitionDone = false;
        recognizedFoods = new();
        recognitionError = string.Empty;
    }

    // ─── Análisis IA ──────────────────────────────────────────────────────
    private async Task AnalyzePhoto()
    {
        if (photoBytes == null) return;

        isAnalyzing = true;
        recognitionError = string.Empty;
        recognitionDone = false;
        recognizedFoods = new();
        StateHasChanged();

        try
        {
            var detected = await FoodRecognition.RecognizeAsync(photoBytes, photoMime);

            if (!detected.Any())
            {
                recognitionDone = true;
                isAnalyzing = false;
                StateHasChanged();
                return;
            }

            // Construir los ViewModels
            recognizedFoods = detected.Select(d => new RecognizedFoodVm
            {
                Name = d.Name,
                Confidence = d.Confidence,
                Selected = true,
                State = RecognitionState.Pending
            }).ToList();

            recognitionDone = true;
            isAnalyzing = false;
            StateHasChanged();

            // Buscar datos nutricionales en paralelo para cada alimento detectado
            var tasks = recognizedFoods.Select(async rf =>
            {
                var results = await NutritionSearch.SearchFoodAsync(rf.Name);
                var best = results.FirstOrDefault(r => r.KcalPer100g > 0);
                rf.FoodData = best;
                rf.State = best != null ? RecognitionState.Found : RecognitionState.NotFound;
                // Si no se encontró con el nombre traducido, buscar en inglés
                if (best == null)
                {
                    var enResults = await NutritionSearch.SearchFoodAsync(
                        detected.First(d => d.Name == rf.Name).Name);
                    var enBest = enResults.FirstOrDefault(r => r.KcalPer100g > 0);
                    if (enBest != null)
                    {
                        enBest.Name = rf.Name; // mantener nombre en español
                        rf.FoodData = enBest;
                        rf.State = RecognitionState.Found;
                    }
                }
                await InvokeAsync(StateHasChanged);
            });

            await Task.WhenAll(tasks);
        }
        catch (Exception)
        {
            recognitionError = "Error al analizar la imagen. Puedes buscar manualmente.";
            isAnalyzing = false;
        }

        StateHasChanged();
    }

    private void AddRecognizedFoods()
    {
        foreach (var rf in recognizedFoods.Where(r => r.Selected && r.State == RecognitionState.Found && r.FoodData != null))
        {
            selectedFoods.Add(new FoodItem
            {
                Name = rf.Name,
                KcalPer100g = rf.FoodData!.KcalPer100g,
                ProteinPer100g = rf.FoodData.ProteinPer100g,
                CarbsPer100g = rf.FoodData.CarbsPer100g,
                FatPer100g = rf.FoodData.FatPer100g,
                QuantityGrams = 100
            });
        }
        // Limpiar selección tras añadir
        foreach (var rf in recognizedFoods) rf.Selected = false;
    }

    // ─── Búsqueda manual ─────────────────────────────────────────────────
    private async Task HandleSearchKeydown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SearchFood();
    }

    private async Task SearchFood()
    {
        if (string.IsNullOrWhiteSpace(searchQuery)) return;
        isSearching = true;
        searchPerformed = true;
        lastQuery = searchQuery;
        searchResults = new();
        apiUnavailable = false;
        StateHasChanged();

        var results = await NutritionSearch.SearchFoodAsync(searchQuery);
        apiUnavailable = results.Any() && results.All(r => r.ImageUrl == null);
        searchResults = results;
        isSearching = false;
    }

    private void AddFromSearch(FoodItem item)
    {
        selectedFoods.Add(new FoodItem
        {
            Name = item.Name,
            KcalPer100g = item.KcalPer100g,
            ProteinPer100g = item.ProteinPer100g,
            CarbsPer100g = item.CarbsPer100g,
            FatPer100g = item.FatPer100g,
            ImageUrl = item.ImageUrl,
            QuantityGrams = 100
        });
        searchResults = new();
        searchQuery = string.Empty;
        searchPerformed = false;
        apiUnavailable = false;
    }

    private void AddManualFood()
        => selectedFoods.Add(new FoodItem { Name = "Nuevo alimento", QuantityGrams = 100 });

    private void RemoveFood(FoodItem food) => selectedFoods.Remove(food);

    // ─── Guardar ─────────────────────────────────────────────────────────
    private async Task SaveMeal()
    {
        if (!selectedFoods.Any()) { errorMsg = "Añade al menos un alimento."; return; }
        await MealLog.SaveAsync(new MealEntry
        {
            Date = mealDate,
            MealType = mealType,
            Foods = new List<FoodItem>(selectedFoods),
            Notes = notes
        });
        Nav.NavigateTo("food");
    }

    // ─── DTO para JSInterop ───────────────────────────────────────────────
    private class CameraResult
    {
        [System.Text.Json.Serialization.JsonPropertyName("base64")]
        public string Base64 { get; set; } = string.Empty;

        [System.Text.Json.Serialization.JsonPropertyName("mimeType")]
        public string MimeType { get; set; } = "image/jpeg";

        [System.Text.Json.Serialization.JsonPropertyName("dataUrl")]
        public string DataUrl { get; set; } = string.Empty;
    }
}
