@page "/food"

@inject IMealLogService MealLog
@inject IUserProfileService ProfileService
@inject IFoodRecognitionService FoodRecognition

<PageTitle>Registro de Comidas</PageTitle>

<div class="page-food">
    <div class="page-header">
        <h2>🍽️ Registro de Comidas</h2>
        <div class="date-nav">
            <button class="btn-nav" @onclick="PrevDay">◀</button>
            <span class="date-display">@selectedDate.ToString("ddd, d MMM yyyy")</span>
            <button class="btn-nav" @onclick="NextDay" disabled="@(selectedDate.Date >= DateTime.Today)">▶</button>
        </div>
    </div>

    <!-- Resumen del día -->
    <div class="daily-summary-bar">
        <div class="summary-pill">
            <span class="pill-value">@totalKcal.ToString("0")</span>
            <span class="pill-label">kcal</span>
        </div>
        <div class="summary-pill protein">
            <span class="pill-value">@totalProtein.ToString("0")g</span>
            <span class="pill-label">proteína</span>
        </div>
        <div class="summary-pill carbs">
            <span class="pill-value">@totalCarbs.ToString("0")g</span>
            <span class="pill-label">carbos</span>
        </div>
        <div class="summary-pill fat">
            <span class="pill-value">@totalFat.ToString("0")g</span>
            <span class="pill-label">grasa</span>
        </div>
    </div>

    <!-- Barra de objetivo -->
    <div class="kcal-goal-bar">
        <div class="goal-labels">
            <span>0 kcal</span>
            <span class="goal-target">Objetivo: @(profile?.DailyCalorieGoal ?? 2000) kcal</span>
        </div>
        <div class="progress-bar-container">
            <div class="progress-bar-fill @(totalKcal > (profile?.DailyCalorieGoal ?? 2000) ? "bar-over" : "bar-ok")"
                 style="width: @Math.Min((int)(totalKcal / (profile?.DailyCalorieGoal ?? 2000) * 100), 100)%">
            </div>
        </div>
    </div>

    <!-- Comidas agrupadas por tipo -->
    @foreach (MealType type in Enum.GetValues(typeof(MealType)))
    {
        var mealsOfType = meals.Where(m => m.MealType == type).ToList();
        <div class="meal-group">
            <div class="meal-group-header">
                <span class="meal-type-badge @GetMealTypeClass(type)">@GetMealTypeEmoji(type) @type</span>
                <span class="meal-group-kcal">@mealsOfType.Sum(m => m.TotalKcal).ToString("0") kcal</span>
                <a href="food/add?type=@((int)type)&date=@selectedDate.ToString("yyyy-MM-dd")" class="btn-add-small">+ Añadir</a>
            </div>
            @if (!mealsOfType.Any())
            {
                <p class="empty-meal">Sin registros</p>
            }
            else
            {
                @foreach (var meal in mealsOfType)
                {
                    <div class="meal-card">
                        <div class="meal-card-top">
                            @foreach (var food in meal.Foods)
                            {
                                <div class="food-row">
                                    <span class="food-name">@food.Name</span>
                                    <span class="food-qty">@food.QuantityGrams g</span>
                                    <span class="food-kcal">@food.TotalKcal.ToString("0") kcal</span>
                                </div>
                            }
                        </div>
                        <div class="meal-card-footer">
                            <span class="macro-tag p-tag">P: @meal.TotalProtein.ToString("0")g</span>
                            <span class="macro-tag c-tag">C: @meal.TotalCarbs.ToString("0")g</span>
                            <span class="macro-tag f-tag">G: @meal.TotalFat.ToString("0")g</span>
                            <button class="btn-delete" @onclick="() => DeleteMeal(meal.Id)">🗑️</button>
                        </div>
                    </div>
                }
            }
        </div>
    }

    <div class="fab-container @(meals.Any() && FoodRecognition.HasApiKey ? "fab-row" : "")">
        @if (meals.Any() && FoodRecognition.HasApiKey)
        {
            <button class="fab fab-analyze" @onclick="OpenDietAnalysis" disabled="@isAnalyzingDiet">
                @if (isAnalyzingDiet)
                { <span>⏳ Analizando...</span> }
                else
                { <span>🧠 Analizar dieta</span> }
            </button>
        }
        <a href="food/add?date=@selectedDate.ToString("yyyy-MM-dd")" class="fab">+ Añadir comida</a>
    </div>
</div>

<!-- Panel de análisis de dieta del día -->
@if (showAnalysisPanel)
{
    <div class="diet-panel-overlay" @onclick="ClosePanel"></div>
    <div class="diet-panel @(showAnalysisPanel ? "diet-panel-open" : "")">
        <div class="diet-panel-header">
            <div>
                <span class="diet-panel-title">🧠 Análisis de la dieta</span>
                <span class="diet-panel-date">@selectedDate.ToString("ddd, d MMM yyyy")</span>
            </div>
            <button class="diet-panel-close" @onclick="ClosePanel">✕</button>
        </div>

        @if (isAnalyzingDiet)
        {
            <div class="diet-panel-loading">
                <div class="loading-spinner"></div>
                <p>La IA está analizando tu dieta de hoy...</p>
            </div>
        }
        else if (!string.IsNullOrEmpty(dietAnalysisError))
        {
            <div class="info-banner warn">⚠️ @dietAnalysisError</div>
        }
        else if (dietAnalysisResult != null)
        {
            <!-- Resumen de macros del día -->
            <div class="diet-panel-macros">
                <div class="dp-macro">
                    <span class="dp-macro-val">@totalKcal.ToString("0")</span>
                    <span class="dp-macro-lbl">kcal</span>
                </div>
                <div class="dp-macro protein">
                    <span class="dp-macro-val">@totalProtein.ToString("0")g</span>
                    <span class="dp-macro-lbl">proteína</span>
                </div>
                <div class="dp-macro carbs">
                    <span class="dp-macro-val">@totalCarbs.ToString("0")g</span>
                    <span class="dp-macro-lbl">carbos</span>
                </div>
                <div class="dp-macro fat">
                    <span class="dp-macro-val">@totalFat.ToString("0")g</span>
                    <span class="dp-macro-lbl">grasa</span>
                </div>
            </div>

            <!-- Evaluación general -->
            <div class="diet-overall">
                <span class="diet-overall-label">📋 Evaluación general</span>
                <p class="diet-overall-text">@dietAnalysisResult.OverallAssessment</p>
            </div>

            <!-- Recomendaciones -->
            @if (dietAnalysisResult.Recommendations.Any())
            {
                <div class="diet-recommendations">
                    <span class="diet-rec-title">💡 Recomendaciones para tu objetivo</span>
                    <ul class="diet-rec-list">
                        @foreach (var rec in dietAnalysisResult.Recommendations)
                        {
                            <li class="diet-rec-item">@rec</li>
                        }
                    </ul>
                </div>
            }

            <button class="btn-reanalyze" @onclick="OpenDietAnalysis">🔄 Volver a analizar</button>
        }
    </div>
}

@code {
    private List<MealEntry> meals = new();
    private UserProfile? profile;
    private DateTime selectedDate = DateTime.Today;
    private double totalKcal, totalProtein, totalCarbs, totalFat;

    // ─── Análisis de dieta ────────────────────────────────────────────────────
    private bool showAnalysisPanel = false;
    private bool isAnalyzingDiet = false;
    private string dietAnalysisError = string.Empty;
    private DietDayAnalysisResult? dietAnalysisResult;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            profile = await ProfileService.GetAsync();
            await LoadMeals();
        }
        catch { }
    }

    private async Task LoadMeals()
    {
        meals = await MealLog.GetByDateAsync(selectedDate);
        totalKcal    = meals.Sum(m => m.TotalKcal);
        totalProtein = meals.Sum(m => m.TotalProtein);
        totalCarbs   = meals.Sum(m => m.TotalCarbs);
        totalFat     = meals.Sum(m => m.TotalFat);
        // Reset análisis al cambiar de día
        showAnalysisPanel  = false;
        dietAnalysisResult = null;
        dietAnalysisError  = string.Empty;
    }

    private async Task PrevDay()
    {
        selectedDate = selectedDate.AddDays(-1);
        await LoadMeals();
    }

    private async Task NextDay()
    {
        if (selectedDate.Date < DateTime.Today)
        {
            selectedDate = selectedDate.AddDays(1);
            await LoadMeals();
        }
    }

    private async Task OpenDietAnalysis()
    {
        showAnalysisPanel  = true;
        isAnalyzingDiet    = true;
        dietAnalysisError  = string.Empty;
        dietAnalysisResult = null;
        StateHasChanged();
        try
        {
            var currentProfile = profile ?? await ProfileService.GetAsync();
            dietAnalysisResult = await FoodRecognition.AnalyzeDayDietAsync(
                meals, new List<FoodItem>(), "Resumen del día", currentProfile);
            if (!dietAnalysisResult.Success)
            {
                dietAnalysisError  = dietAnalysisResult.Error!;
                dietAnalysisResult = null;
            }
        }
        catch (Exception ex)
        {
            dietAnalysisError = "Error inesperado: " + ex.Message;
        }
        isAnalyzingDiet = false;
        StateHasChanged();
    }

    private void ClosePanel()
    {
        showAnalysisPanel = false;
        StateHasChanged();
    }

    private async Task DeleteMeal(Guid id)    {
        await MealLog.DeleteAsync(id);
        await LoadMeals();
    }

    private string GetMealTypeClass(MealType type) => type switch
    {
        MealType.Desayuno => "badge-desayuno",
        MealType.Almuerzo => "badge-almuerzo",
        MealType.Comida   => "badge-comida",
        MealType.Merienda => "badge-merienda",
        MealType.Cena     => "badge-cena",
        _                 => "badge-snack"
    };

    private string GetMealTypeEmoji(MealType type) => type switch
    {
        MealType.Desayuno => "☀️",
        MealType.Almuerzo => "🥗",
        MealType.Comida   => "🍽️",
        MealType.Merienda => "🍎",
        MealType.Cena     => "🌙",
        _                 => "🍴"
    };
}

