@page "/"

@inject IMealLogService MealLog
@inject IWorkoutLogService WorkoutLog
@inject IUserProfileService ProfileService

<PageTitle>Dashboard – AppFitness</PageTitle>

<div class="dashboard">
    <div class="dashboard-header">
        <h1>👋 Hola, @profile?.Name</h1>
        <p class="date-label">@DateTime.Today.ToString("dddd, d MMMM yyyy")</p>
    </div>

    <!-- Calorías del día -->
    <div class="card-fitness card-calories">
        <div class="card-header-fitness">
            <span class="card-icon">🔥</span>
            <span>Calorías hoy</span>
        </div>
        <div class="kcal-display">
            <span class="kcal-consumed">@todayKcal.ToString("0")</span>
            <span class="kcal-separator"> / </span>
            <span class="kcal-goal">@(profile?.DailyCalorieGoal ?? 2000) kcal</span>
        </div>
        <div class="progress-bar-container">
            <div class="progress-bar-fill @GetCalorieBarClass()" style="width: @GetCaloriePercent()%"></div>
        </div>
        <p class="kcal-remaining">
            @if (remaining > 0)
            { <span class="text-success">@remaining.ToString("0") kcal restantes</span> }
            else
            { <span class="text-danger">@Math.Abs(remaining).ToString("0") kcal de exceso</span> }
        </p>
    </div>

    <!-- Macros -->
    <div class="card-fitness card-macros">
        <div class="card-header-fitness">
            <span class="card-icon">🥗</span>
            <span>Macros de hoy</span>
        </div>
        <div class="macros-grid">
            <div class="macro-item">
                <span class="macro-label">Proteína</span>
                <span class="macro-value protein">@todayProtein.ToString("0")g</span>
            </div>
            <div class="macro-item">
                <span class="macro-label">Carbos</span>
                <span class="macro-value carbs">@todayCarbs.ToString("0")g</span>
            </div>
            <div class="macro-item">
                <span class="macro-label">Grasa</span>
                <span class="macro-value fat">@todayFat.ToString("0")g</span>
            </div>
        </div>
    </div>

    <!-- Comidas de hoy -->
    <div class="card-fitness">
        <div class="card-header-fitness">
            <span class="card-icon">🍽️</span>
            <span>Comidas de hoy</span>
            <a href="food/add" class="btn-add">+ Añadir</a>
        </div>
        @if (!todayMeals.Any())
        {
            <p class="empty-state">No hay comidas registradas hoy.</p>
        }
        else
        {
            @foreach (var meal in todayMeals)
            {
                <div class="meal-summary-item">
                    <span class="meal-type-badge @GetMealTypeClass(meal.MealType)">@meal.MealType</span>
                    <span class="meal-foods">@string.Join(", ", meal.Foods.Select(f => f.Name))</span>
                    <span class="meal-kcal">@meal.TotalKcal.ToString("0") kcal</span>
                </div>
            }
        }
    </div>

    <!-- Gráfico últimos 7 días -->
    <div class="card-fitness">
        <div class="card-header-fitness">
            <span class="card-icon">📊</span>
            <span>Últimos 7 días</span>
            <a href="food/history" class="btn-add">Ver más</a>
        </div>
        <div class="week-chart">
            @foreach (var day in weekData)
            {
                var pct = profile?.DailyCalorieGoal > 0
                    ? Math.Min((int)(day.Kcal / profile.DailyCalorieGoal * 100), 100)
                    : 0;
                var barClass = day.Kcal > (profile?.DailyCalorieGoal ?? 2000) ? "bar-over" : "bar-ok";
                <div class="chart-col">
                    <div class="chart-bar-wrap">
                        <div class="chart-bar @barClass" style="height: @pct%;" title="@day.Kcal.ToString("0") kcal"></div>
                    </div>
                    <span class="chart-label">@day.Label</span>
                </div>
            }
        </div>
    </div>

    <!-- Último entrenamiento -->
    <div class="card-fitness">
        <div class="card-header-fitness">
            <span class="card-icon">💪</span>
            <span>Último entrenamiento</span>
            <a href="workout/add" class="btn-add">+ Nuevo</a>
        </div>
        @if (lastWorkout == null)
        {
            <p class="empty-state">No hay entrenamientos registrados.</p>
        }
        else
        {
            <div class="workout-summary">
                <span class="workout-date">📅 @lastWorkout.Date.ToString("dd/MM/yyyy")</span>
                <span class="workout-sets">🏋️ @lastWorkout.TotalSets series</span>
                <span class="workout-volume">⚡ @lastWorkout.TotalVolume.ToString("0") kg vol.</span>
            </div>
            @foreach (var set in lastWorkout.Sets.Take(3))
            {
                <div class="set-item">
                    <span>@set.ExerciseName</span>
                    <span class="set-detail">@set.Sets×@set.Reps reps · @set.WeightKg kg</span>
                </div>
            }
        }
    </div>

    <!-- Accesos rápidos -->
    <div class="quick-actions">
        <a href="food/add" class="quick-btn btn-food">📸 Registrar comida</a>
        <a href="workout/add" class="quick-btn btn-workout">🏋️ Nuevo entreno</a>
        <a href="profile" class="quick-btn btn-profile">👤 Mi perfil</a>
    </div>
</div>

@code {
    private UserProfile? profile;
    private List<MealEntry> todayMeals = new();
    private double todayKcal, todayProtein, todayCarbs, todayFat;
    private double remaining;
    private WorkoutSession? lastWorkout;
    private List<(string Label, double Kcal)> weekData = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            profile = await ProfileService.GetAsync();
            todayMeals = await MealLog.GetByDateAsync(DateTime.Today);
            todayKcal = todayMeals.Sum(m => m.TotalKcal);
            todayProtein = todayMeals.Sum(m => m.TotalProtein);
            todayCarbs = todayMeals.Sum(m => m.TotalCarbs);
            todayFat = todayMeals.Sum(m => m.TotalFat);
            remaining = (profile?.DailyCalorieGoal ?? 2000) - todayKcal;

            var sessions = await WorkoutLog.GetAllAsync();
            lastWorkout = sessions.OrderByDescending(s => s.Date).FirstOrDefault();

            weekData = new();
            for (int i = 6; i >= 0; i--)
            {
                var d = DateTime.Today.AddDays(-i);
                var kcal = await MealLog.GetDailyKcalAsync(d);
                weekData.Add((d.ToString("ddd"), kcal));
            }
        }
        catch
        {
            // Evitar que excepciones de inicialización disparen el panel de error de Blazor
        }
    }

    private int GetCaloriePercent()
    {
        if (profile == null || profile.DailyCalorieGoal <= 0) return 0;
        return (int)Math.Min(todayKcal / profile.DailyCalorieGoal * 100, 100);
    }

    private string GetCalorieBarClass()
        => todayKcal > (profile?.DailyCalorieGoal ?? 2000) ? "bar-over" : "bar-ok";

    private string GetMealTypeClass(MealType type) => type switch
    {
        MealType.Desayuno  => "badge-desayuno",
        MealType.Almuerzo  => "badge-almuerzo",
        MealType.Comida    => "badge-comida",
        MealType.Merienda  => "badge-merienda",
        MealType.Cena      => "badge-cena",
        _                  => "badge-snack"
    };
}