@inherits LayoutComponentBase
@inject ILocalStorageService Storage
@inject IFoodRecognitionService FoodRecognition

<div class="page">
    <div class="sidebar">
        <NavMenu/>
    </div>

    <main>
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Si el servicio ya tiene key (inyectada por GitHub Actions en appsettings.json), no hacer nada
            if (!FoodRecognition.HasApiKey)
            {
                // Intentar cargar desde localStorage (guardada por el usuario en Settings)
                var storedKey = await Storage.GetAsync<string>("gemini_api_key");
                if (!string.IsNullOrWhiteSpace(storedKey))
                    FoodRecognition.SetApiKey(storedKey);
            }
        }
        catch
        {
            // Ignorar errores de inicialización para no disparar blazor-error-ui
        }
    }
}

